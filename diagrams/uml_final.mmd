classDiagram
    class Owner {
        +str name
        +int time_available_minutes
        +list~str~ preferences
        +list~Pet~ pets
        +add_pet(pet: Pet) None
        +set_time_available(minutes: int) None
        +get_pets() list~Pet~
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~PetCareTask~ tasks
        +add_task(task: PetCareTask) None
        +complete_task(title: str) PetCareTask
        +remove_task(title: str) None
        +get_tasks() list~PetCareTask~
        +clear_tasks() None
    }

    class PetCareTask {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +bool is_recurring
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() PetCareTask
        +is_high_priority() bool
        +to_dict() dict
    }

    class Scheduler {
        +str start_time
        +int time_limit_minutes
        +build_plan(pets: list~Pet~, owner: Owner) DailyPlan
        +sort_tasks(tasks: list~PetCareTask~, preferences: list~str~, task_pet: dict) list~PetCareTask~
        +sort_by_time(tasks: list~PetCareTask~, reverse: bool) list~PetCareTask~
        +filter_tasks(tasks: list~PetCareTask~, time_remaining: int) list~PetCareTask~
        +filter_tasks_by(tasks: list~PetCareTask~, task_pet: dict, completed: bool, pet_name: str) list~PetCareTask~
        +find_conflicts(items: list~ScheduledItem~) list
        +check_conflicts(items: list~ScheduledItem~) bool
        +warn_conflicts(items: list~ScheduledItem~) str
    }

    class DailyPlan {
        +str date
        +list~ScheduledItem~ scheduled_items
        +int total_duration_minutes
        +list~dict~ skipped_tasks
        +int breaks_inserted
        +list~dict~ conflicts
        +add_item(item: ScheduledItem) None
        +add_conflict(a: ScheduledItem, b: ScheduledItem) None
        +skip_task(task: PetCareTask, reason: str, pet_name: str) None
        +display() str
        +explain() str
        +get_summary() dict
    }

    class ScheduledItem {
        +PetCareTask task
        +str start_time
        +str end_time
        +str reason
        +str pet_name
        +duration() int
        +to_dict() dict
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" PetCareTask : has tasks
    PetCareTask ..> PetCareTask : mark_complete() returns next occurrence
    Scheduler "1" ..> "1" Owner : reads constraints
    Scheduler "1" ..> "1..*" Pet : reads tasks
    Scheduler "1" --> "1" DailyPlan : creates
    DailyPlan "1" --> "0..*" ScheduledItem : contains
    ScheduledItem "1" --> "1" PetCareTask : wraps
